#!/usr/bin/env bash
# cstack-qa-secrets-init — interactive setup for QA agent credentials.
#
# Reads the role manifest from the WORK repo (qa/actors.json), prompts you
# for each role's username + password, and writes them to ~/.cstack-secrets/
# in the two-line format the supervisor expects (line 1 = username,
# line 2 = password). Handles both the single-user identity used by /qa and
# the per-role identities used by /workflow-qa.
#
# Usage:
#   cstack-qa-secrets-init                                 # interactive, all prompts
#   cstack-qa-secrets-init --slug <slug> --repo <path>     # skip those prompts
#   cstack-qa-secrets-init --rotate <role>                 # only re-enter one role
#   cstack-qa-secrets-init --list                          # show what's configured
#
# Files written (all chmod 600, dir chmod 700):
#   ~/.cstack-secrets/<slug>-qa                            # single-user identity
#   ~/.cstack-secrets/<slug>-qa-actor-<role>               # one per role
#
# Each file is exactly two lines: username\npassword\n
#
# Role discovery — in priority order:
#   1. --roles a,b,c                       (CLI flag wins)
#   2. <repo>/qa/actors.json               ({"roles": [...]} or {"role": {...}})
#   3. interactive prompt                  (asks for comma-separated list)
#
# After successful setup, this script rewrites qa/actors.json to the canonical
# manifest form: {"roles": ["a", "b", "c"]} — no usernames, no passwords.
# Usernames live in the secret file from now on.

set -euo pipefail

SECRETS_DIR="$HOME/.cstack-secrets"
SLUG=""
REPO=""
ROLES_CSV=""
ROTATE_ROLE=""
LIST_ONLY=0
FROM_STDIN=0

# ─── Argument parsing ────────────────────────────────────────
while [ $# -gt 0 ]; do
  case "$1" in
    --slug)        SLUG="$2"; shift 2 ;;
    --repo)        REPO="$2"; shift 2 ;;
    --roles)       ROLES_CSV="$2"; shift 2 ;;
    --rotate)      ROTATE_ROLE="$2"; shift 2 ;;
    --list)        LIST_ONLY=1; shift ;;
    --from-stdin)  FROM_STDIN=1; shift ;;
    -h|--help)     sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

# ─── Helpers ─────────────────────────────────────────────────
die()  { echo "error: $*" >&2; exit 1; }
warn() { echo "warning: $*" >&2; }
say()  { printf '%s\n' "$*"; }

# Prompt for a single line (visible). Sets $REPLY.
prompt() {
  local label="$1" default="${2-}"
  if [ -n "$default" ]; then
    printf '%s [%s]: ' "$label" "$default" >&2
  else
    printf '%s: ' "$label" >&2
  fi
  IFS= read -r REPLY </dev/tty || die "no tty for prompt"
  [ -n "$REPLY" ] || REPLY="$default"
}

# Prompt for a secret (hidden). Sets $REPLY. Asks twice and confirms match.
prompt_secret() {
  local label="$1" first="" second=""
  while :; do
    printf '%s: ' "$label" >&2
    IFS= read -rs first </dev/tty || die "no tty for secret prompt"
    printf '\n' >&2
    printf '%s (confirm): ' "$label" >&2
    IFS= read -rs second </dev/tty || die "no tty for secret prompt"
    printf '\n' >&2
    if [ "$first" = "$second" ] && [ -n "$first" ]; then
      REPLY="$first"
      return 0
    fi
    [ -z "$first" ] && warn "empty password rejected — try again"
    [ -n "$first" ] && [ "$first" != "$second" ] && warn "passwords did not match — try again"
  done
}

# Write a two-line credential file with strict permissions.
# Args: <file-path> <username> <password>
write_cred_file() {
  local path="$1" user="$2" pass="$3"
  ( umask 077; printf '%s\n%s\n' "$user" "$pass" > "$path" )
  chmod 600 "$path"
}

# Parse qa/actors.json (tolerant: accepts old or new shape).
# Echoes role names one per line. Prints nothing if file absent or empty.
read_roles_from_json() {
  local json="$1"
  [ -f "$json" ] || return 0
  python3 - "$json" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
except Exception as e:
    sys.stderr.write(f"warning: could not parse {sys.argv[1]}: {e}\n")
    sys.exit(0)

# Accepted shapes:
#   {"roles": ["a", "b"]}            ← canonical
#   ["a", "b"]                       ← bare array
#   {"a": {...}, "b": {...}}         ← legacy (usernames embedded)
roles = []
if isinstance(data, dict):
    if "roles" in data and isinstance(data["roles"], list):
        roles = [str(r) for r in data["roles"]]
    else:
        roles = [k for k in data.keys() if isinstance(k, str)]
elif isinstance(data, list):
    roles = [str(r) for r in data]

for r in roles:
    print(r)
PY
}

# Write canonical qa/actors.json from a role list.
write_canonical_actors_json() {
  local json="$1"; shift
  mkdir -p "$(dirname "$json")"
  python3 - "$json" "$@" <<'PY'
import json, sys
path = sys.argv[1]
roles = sys.argv[2:]
with open(path, "w") as f:
    json.dump({"roles": roles}, f, indent=2)
    f.write("\n")
PY
}

# Validate slug: lowercase letters, digits, hyphens, 1-32 chars.
valid_slug() {
  printf '%s' "$1" | grep -Eq '^[a-z][a-z0-9-]{0,31}$'
}

# Validate role name: lowercase letters, digits, underscores, hyphens.
valid_role() {
  printf '%s' "$1" | grep -Eq '^[a-z][a-z0-9_-]{0,63}$'
}

# ─── List mode (early exit) ─────────────────────────────────
if [ "$LIST_ONLY" -eq 1 ]; then
  [ -d "$SECRETS_DIR" ] || { say "no secrets dir at $SECRETS_DIR"; exit 0; }
  say "secrets in $SECRETS_DIR (showing slugs and roles only — never values):"
  ls -1 "$SECRETS_DIR" 2>/dev/null | awk -F'-qa' '
    /-qa$/         { printf "  %-20s  single-user identity\n", $1 }
    /-qa-actor-/   { sub(/^-actor-/, "", $2); printf "  %-20s  role: %s\n", $1, $2 }
  ' | sort -u
  exit 0
fi

# ─── Non-interactive mode (from JSON on stdin) ──────────────
# Schema:
# {
#   "slug": "dsti",
#   "repo": "/path/to/work/repo",                  # optional, only needed to rewrite qa/actors.json
#   "single_user": {"username": "...", "password": "..."},   # optional
#   "actors": [                                                # optional, one per role
#     {"role": "approver", "username": "...", "password": "..."},
#     ...
#   ]
# }
# Reads the JSON, writes every credential file, rewrites qa/actors.json if repo
# given, then exits. Never prompts. Exit 0 on success, 1 on schema error.
if [ "$FROM_STDIN" -eq 1 ]; then
  TMP_JSON="$(mktemp)"
  trap 'rm -f "$TMP_JSON"' EXIT
  cat > "$TMP_JSON"
  mkdir -p "$SECRETS_DIR"
  chmod 700 "$SECRETS_DIR"
  python3 - "$TMP_JSON" "$SECRETS_DIR" <<'PY'
import json, os, re, stat, sys
spec_path, secrets_dir = sys.argv[1], sys.argv[2]
try:
    spec = json.load(open(spec_path))
except Exception as e:
    sys.stderr.write(f"error: invalid JSON on stdin: {e}\n"); sys.exit(1)

slug = spec.get("slug", "")
if not re.match(r"^[a-z][a-z0-9-]{0,31}$", slug):
    sys.stderr.write(f"error: invalid slug '{slug}'\n"); sys.exit(1)

def write_file(path, user, pw):
    if not user or not pw:
        sys.stderr.write(f"error: empty username or password for {path}\n"); sys.exit(1)
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    with os.fdopen(fd, "w") as f:
        f.write(f"{user}\n{pw}\n")
    os.chmod(path, 0o600)
    print(f"wrote {path}", file=sys.stderr)

su = spec.get("single_user")
if su:
    write_file(os.path.join(secrets_dir, f"{slug}-qa"),
               su.get("username", ""), su.get("password", ""))

actors = spec.get("actors", [])
role_names = []
for a in actors:
    role = a.get("role", "")
    if not re.match(r"^[a-z][a-z0-9_-]{0,63}$", role):
        sys.stderr.write(f"error: invalid role '{role}'\n"); sys.exit(1)
    role_names.append(role)
    write_file(os.path.join(secrets_dir, f"{slug}-qa-actor-{role}"),
               a.get("username", ""), a.get("password", ""))

# Rewrite qa/actors.json if repo path provided.
repo = spec.get("repo")
if repo and role_names:
    actors_json = os.path.join(repo, "qa", "actors.json")
    os.makedirs(os.path.dirname(actors_json), exist_ok=True)
    with open(actors_json, "w") as f:
        json.dump({"roles": role_names}, f, indent=2)
        f.write("\n")
    print(f"wrote {actors_json}", file=sys.stderr)
PY
  exit $?
fi

# ─── List mode handled above; from-stdin handled above ──────

# ─── Slug discovery ─────────────────────────────────────────
if [ -z "$SLUG" ]; then
  # Try reading from agent-qa config (covers the common case).
  if [ -f "$HOME/agents/agent-qa/config" ]; then
    SLUG="$(grep -E '^SECRET_PREFIX=' "$HOME/agents/agent-qa/config" | cut -d= -f2- | tr -d '"' | tr -d "'" | head -1 || true)"
  fi
fi
if [ -z "$SLUG" ]; then
  prompt "Engagement slug (lowercase, e.g. dsti, acme, contoso)"
  SLUG="$REPLY"
fi
valid_slug "$SLUG" || die "invalid slug '$SLUG' — must be lowercase, start with a letter, only [a-z0-9-]"

# ─── Repo discovery (only needed if --roles not supplied and not rotating one role) ──
need_repo=0
if [ -z "$ROTATE_ROLE" ] && [ -z "$ROLES_CSV" ]; then
  need_repo=1
fi

if [ "$need_repo" -eq 1 ] && [ -z "$REPO" ]; then
  # Try the conventional WORK dir location for agent-qa.
  if [ -d "$HOME/agents/agent-qa/work" ]; then
    REPO="$HOME/agents/agent-qa/work"
  elif [ -d "$HOME/agents/agent-be/work" ]; then
    REPO="$HOME/agents/agent-be/work"
  fi
fi

if [ "$need_repo" -eq 1 ] && [ -z "$REPO" ]; then
  prompt "Path to WORK repo (where qa/actors.json lives)"
  REPO="$REPLY"
fi

if [ "$need_repo" -eq 1 ]; then
  [ -d "$REPO" ] || die "WORK repo not found at $REPO"
fi

ACTORS_JSON="${REPO:+$REPO/qa/actors.json}"

# ─── Role list resolution ────────────────────────────────────
ROLES=()

if [ -n "$ROTATE_ROLE" ]; then
  ROLES=("$ROTATE_ROLE")
elif [ -n "$ROLES_CSV" ]; then
  IFS=',' read -ra ROLES <<< "$ROLES_CSV"
elif [ -n "$ACTORS_JSON" ] && [ -f "$ACTORS_JSON" ]; then
  while IFS= read -r line; do
    [ -n "$line" ] && ROLES+=("$line")
  done < <(read_roles_from_json "$ACTORS_JSON")
  if [ ${#ROLES[@]} -eq 0 ]; then
    warn "qa/actors.json exists but contains no roles"
  fi
fi

if [ ${#ROLES[@]} -eq 0 ] && [ -z "$ROTATE_ROLE" ]; then
  say ""
  say "No roles found. Enter the role names declared by your workflow source"
  say "(comma-separated, exactly as your application's code refers to them)."
  say "Example: requester,approver,admin  — but use YOUR real role names."
  prompt "Roles"
  IFS=',' read -ra ROLES <<< "$REPLY"
fi

# Trim whitespace and validate each role.
CLEAN_ROLES=()
for r in "${ROLES[@]}"; do
  r="$(printf '%s' "$r" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [ -z "$r" ] && continue
  valid_role "$r" || die "invalid role name '$r' — must be lowercase, start with a letter, only [a-z0-9_-]"
  CLEAN_ROLES+=("$r")
done
ROLES=("${CLEAN_ROLES[@]}")

[ ${#ROLES[@]} -gt 0 ] || die "no valid roles to configure"

# ─── Prepare secrets dir ─────────────────────────────────────
mkdir -p "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"

# ─── Single-user identity (skip if rotating a specific role) ──
if [ -z "$ROTATE_ROLE" ]; then
  USER_FILE="$SECRETS_DIR/${SLUG}-qa"
  if [ -f "$USER_FILE" ]; then
    say ""
    prompt "Single-user identity already set for '$SLUG'. Overwrite? [y/N]"
    case "${REPLY,,}" in
      y|yes) ;;
      *) say "  keeping existing single-user identity"; USER_FILE="" ;;
    esac
  fi
  if [ -n "$USER_FILE" ]; then
    say ""
    say "── Single-user identity (used by /qa) ──"
    prompt "  Username (email or login)"
    SU_USER="$REPLY"
    [ -n "$SU_USER" ] || die "username cannot be empty"
    prompt_secret "  Password"
    SU_PASS="$REPLY"
    write_cred_file "$USER_FILE" "$SU_USER" "$SU_PASS"
    say "  wrote $USER_FILE"
    unset SU_USER SU_PASS
  fi
fi

# ─── Per-role identities ─────────────────────────────────────
say ""
say "── Per-role identities (used by /workflow-qa) ──"
for role in "${ROLES[@]}"; do
  FILE="$SECRETS_DIR/${SLUG}-qa-actor-${role}"
  if [ -f "$FILE" ] && [ -z "$ROTATE_ROLE" ]; then
    prompt "Role '$role' already configured. Overwrite? [y/N]"
    case "${REPLY,,}" in
      y|yes) ;;
      *) say "  skipping $role"; continue ;;
    esac
  fi
  say ""
  say "  Role: $role"
  prompt "    Username (email or login)"
  R_USER="$REPLY"
  [ -n "$R_USER" ] || die "username cannot be empty"
  prompt_secret "    Password"
  R_PASS="$REPLY"
  write_cred_file "$FILE" "$R_USER" "$R_PASS"
  say "  wrote $FILE"
  unset R_USER R_PASS
done

# ─── Canonicalize qa/actors.json ─────────────────────────────
# Only do this for full setup (not single-role rotation).
if [ -z "$ROTATE_ROLE" ] && [ -n "$ACTORS_JSON" ]; then
  write_canonical_actors_json "$ACTORS_JSON" "${ROLES[@]}"
  say ""
  say "wrote canonical role manifest to $ACTORS_JSON"
  say "  → commit it in the WORK repo: git add qa/actors.json && git commit -m 'qa: actor manifest'"
fi

say ""
say "done. agent-qa will load these on next session start."
say "verify with: $(basename "$0") --list"
