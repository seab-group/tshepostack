#!/usr/bin/env python3
"""
task — deterministic ledger operations for the cstack autonomous loop.
Lives at kernel/task in the control repo. Agents invoke this instead of editing
ledger files themselves: the model decides WHAT, this script executes HOW.

Ledger format: one flat key:value file per task at ledger/<TASK-ID>.task

Lifecycle (sequential pipeline):
  open → in_progress (feature claims) → testing (feature hands off to qa)
       → documenting (qa passes, hands off to doc) → done (doc completes)
  Any stage → needs_human (failure_count >= 3 or --needs-human)
  Any stage → awaiting_info (parked pending another agent; does not burn failure_count)

Domain routing:
  Task created with domain=be/fe/full. Feature completes → domain flips to qa.
  QA passes → domain flips to doc. Doc completes → status done, domain stays doc.
  QA fails (verdict=failed) → domain reverts to origin_domain, status=open.
  origin_domain is set at creation and never changes.

Usage:
  task eligible --role feature --domain be --repo <repo>    # eligible ids, best first
  task show <id>
  task claim <id> --agent agent-be --role feature
  task complete <id> --agent agent-be --role feature
  task complete <id> --agent agent-qa --role qa --verdict passed|failed|env_error
  task complete <id> --agent agent-doc --role doc
  task fail <id> --agent agent-qa --role qa [--needs-human] [--awaiting-info]
  task release <id> --agent agent-be --role feature
  task resume <id> --agent agent-qa --role qa     # awaiting_info → back to active
  task create <id> --repo R --domain D --desc "..." [--blocked-by A,B] [--spec S] [--locks migrations] ...
  task unblock <id>                                # human-only: clears needs_human

Exclusive resource locks (`locks:` + `lock_state:` fields):
  A task may reserve a named exclusive resource (canonical: `migrations`). The kernel
  guarantees AT MOST ONE task per lock name is `held` at a time. The holder takes the
  lock at first claim and keeps it through the WHOLE lifecycle — including after the
  task reaches `done` — until its branch actually MERGES to main. That matters because
  PRs are merged by a human who may not look for hours: releasing at `done` would let a
  sibling branch off a main that still lacks the migration and mint a colliding number.
  Enforced in `eligible` (a contended task is withheld) and `claim` (a contended claim
  exits 2). Release is explicit, via `lock-release` — driven by the supervisor's
  merge-reaper when the branch lands on main, or by a human (`--abandon` for a closed
  PR). Set the lock at authoring time via `--locks`; agents never edit it.

  task lock-release <id> [--abandon]              # free a lock after merge / abandon

Exit codes: 0 ok · 1 error · 2 lost claim race · 3 nothing eligible
All mutations commit+push with retry-on-reject (pull --rebase, re-verify, push).
"""

import argparse, datetime, os, re, subprocess, sys
try:
    import signal
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)
except (ImportError, AttributeError, ValueError):
    pass

LEDGER_DIR = "ledger"

ROLE_COLUMNS = {
    "feature": {"status", "domain", "claimed_by", "claimed_at", "failure_count"},
    "qa":      {"status", "domain", "claimed_by", "claimed_at", "failure_count"},
    "doc":     {"status", "claimed_by", "claimed_at"},
}

DEFAULTS = {
    "status": "open",
    "claimed_by": "-",
    "claimed_at": "-",
    "blocked_by": "-",
    "locks": "-",
    "lock_state": "-",
    "failure_count": "0",
    "lease_hours": "4",
    "origin_domain": "-",
    "prev_status": "-",
    "spec": "-",
    "done_check": "-",
    "e2e_check": "-",
}

FIELD_ORDER = [
    "id", "repo", "domain", "origin_domain", "status", "claimed_by", "claimed_at",
    "blocked_by", "locks", "lock_state", "failure_count", "lease_hours", "prev_status",
    "spec", "done_check", "e2e_check", "description",
]


def die(msg, code=1):
    print(f"task: {msg}", file=sys.stderr)
    sys.exit(code)


def now_iso():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def run(cmd, check=True):
    r = subprocess.run(cmd, capture_output=True, text=True)
    if check and r.returncode != 0:
        die(f"command failed: {' '.join(cmd)}\n{r.stderr.strip()}")
    return r


def path_for(tid):
    return os.path.join(LEDGER_DIR, f"{tid}.task")


def load(tid):
    p = path_for(tid)
    if not os.path.isfile(p):
        die(f"no such task: {tid}")
    fields = dict(DEFAULTS)
    for line in open(p):
        m = re.match(r"^([a-z_]+):\s?(.*)$", line.rstrip("\n"))
        if m:
            fields[m.group(1)] = m.group(2).strip() or "-"
    fields["id"] = fields.get("id", tid)
    return fields


def save(tid, fields):
    keys = FIELD_ORDER + [k for k in fields if k not in FIELD_ORDER]
    with open(path_for(tid), "w") as f:
        for k in keys:
            if k in fields:
                f.write(f"{k}: {fields[k]}\n")


def all_tasks():
    if not os.path.isdir(LEDGER_DIR):
        return []
    out = []
    for fn in sorted(os.listdir(LEDGER_DIR)):
        if fn.endswith(".task"):
            out.append(load(fn[:-5]))
    return out


def stale(fields, status_field, active_value):
    """True if in active_value state AND lease expired (claimed_at set and old)."""
    if fields.get(status_field) != active_value:
        return False
    if fields.get("claimed_at", "-") == "-":
        return False  # unclaimed — not stale
    try:
        claimed = datetime.datetime.fromisoformat(fields["claimed_at"].replace("Z", "+00:00"))
        lease = float(fields.get("lease_hours", "4"))
        return (datetime.datetime.now(datetime.timezone.utc) - claimed).total_seconds() > lease * 3600
    except ValueError:
        return True


def blocked(fields, index):
    deps = fields.get("blocked_by", "-")
    if deps in ("-", ""):
        return False
    for dep in [d.strip() for d in deps.split(",") if d.strip()]:
        dep_t = index.get(dep)
        if dep_t is None or dep_t.get("status") != "done":
            return True
    return False


# Exclusive locks are tracked by `lock_state`, NOT by pipeline status — because the
# resource (e.g. the migration sequence on main) is only freed when the work MERGES,
# which a human may do hours after the task reaches `done`. States:
#   "-"     idle — declared (`locks: <res>`) but not yet acquired; does not block.
#   "held"  acquired at first claim; blocks every OTHER task sharing the resource
#           through the WHOLE lifecycle, INCLUDING after `done`, until merge.
#   "freed" released after the branch merged to main (auto-reaped or human/`lock-release`).
# A held task that QA bounces back to `open` STAYS held — its unmerged migration still
# exists, so a sibling must not branch a colliding one on top of it.
def lock_holders(fields, index):
    """Other tasks currently holding the same exclusive resource lock as `fields`."""
    res = fields.get("locks", "-")
    if res in ("-", ""):
        return []
    return [o for o in index.values()
            if o["id"] != fields["id"]
            and o.get("locks", "-") == res
            and o.get("lock_state") == "held"]


def lock_contended(fields, index):
    """True if this task's exclusive lock is already held by another active task."""
    return bool(lock_holders(fields, index))


def eligible(role, domain, repo):
    index = {t["id"]: t for t in all_tasks()}
    out = []
    for t in index.values():
        # Hard filters — never eligible regardless of role
        if int(t.get("failure_count", "0")) >= 3 or t.get("status") in ("needs_human", "awaiting_info"):
            continue
        if domain and t.get("domain") not in (domain, "full"):
            continue
        if repo and t.get("repo", "-") not in (repo, "-"):
            continue

        if role == "feature":
            # Unclaimed open tasks (not blocked, lock free) or stale in_progress.
            # A stale in_progress reclaim is the SAME task resuming its own lock,
            # so lock_contended (which excludes self) never withholds a reclaim.
            ok = (t["status"] == "open" and not blocked(t, index) and not lock_contended(t, index)) \
                or stale(t, "status", "in_progress")
        elif role == "qa":
            # Unclaimed testing tasks or stale testing claims
            ok = (t["status"] == "testing" and t.get("claimed_by", "-") == "-") or stale(t, "status", "testing")
        elif role == "doc":
            # Unclaimed documenting tasks or stale documenting claims
            ok = (t["status"] == "documenting" and t.get("claimed_by", "-") == "-") or stale(t, "status", "documenting")
        else:
            die(f"unknown role: {role}")

        if ok:
            out.append(t)

    return [t["id"] for t in out]


def git_sync_push(message, retries=3):
    run(["git", "add", LEDGER_DIR])
    r = subprocess.run(["git", "commit", "-qm", message], capture_output=True, text=True)
    if r.returncode != 0:
        return True  # nothing to commit
    for _ in range(retries):
        if subprocess.run(["git", "push", "-q"], capture_output=True).returncode == 0:
            return True
        run(["git", "pull", "--rebase", "-q"], check=False)
    return False


def cmd_claim(a):
    t = load(a.id)

    if a.role == "feature":
        if t["status"] != "open" and not stale(t, "status", "in_progress"):
            die(f"{a.id} not claimable (status={t['status']})", 2)
        # Exclusive-lock pre-check: refuse if another task holds the same resource.
        # A stale reclaim of the SAME task is exempt (lock_holders excludes self).
        if t["status"] == "open":
            holders = lock_holders(t, {x["id"]: x for x in all_tasks()})
            if holders:
                die(f"{a.id} blocked: lock '{t['locks']}' held by {holders[0]['id']}", 2)
        t["status"] = "in_progress"
        # First acquisition of a declared lock: take it. A reclaim leaves it "held".
        if t.get("locks", "-") not in ("-", "") and t.get("lock_state", "-") == "-":
            t["lock_state"] = "held"
    elif a.role == "qa":
        already_claimed = t.get("claimed_by", "-") != "-"
        if t["status"] != "testing" or (already_claimed and not stale(t, "status", "testing")):
            die(f"{a.id} not claimable for qa (status={t['status']}, claimed={t.get('claimed_by', '-')})", 2)
    elif a.role == "doc":
        already_claimed = t.get("claimed_by", "-") != "-"
        if t["status"] != "documenting" or (already_claimed and not stale(t, "status", "documenting")):
            die(f"{a.id} not claimable for doc (status={t['status']}, claimed={t.get('claimed_by', '-')})", 2)

    t["claimed_by"] = a.agent
    t["claimed_at"] = now_iso()
    save(a.id, t)

    if not git_sync_push(f"claim({a.id}): {a.agent} [{a.role}]"):
        die("push failed after retries", 1)

    # Post-push: verify we still own it
    run(["git", "pull", "--rebase", "-q"], check=False)
    index2 = {x["id"]: x for x in all_tasks()}
    t2 = index2.get(a.id, load(a.id))
    if t2.get("claimed_by") != a.agent:
        die(f"lost claim race on {a.id}", 2)

    # Exclusive-lock tie-break: if a DIFFERENT task also became `held` on the same
    # resource and was claimed at or before us, it wins (earliest claim, ties broken
    # by id). We release our just-acquired lock and yield our claim back to open so
    # only one holder survives a simultaneous first-claim.
    if a.role == "feature":
        mine = (t2.get("claimed_at", "-"), a.id)
        for h in lock_holders(t2, index2):
            if (h.get("claimed_at", "-"), h["id"]) <= mine:
                t2["status"] = "open"
                t2["claimed_by"] = "-"
                t2["claimed_at"] = "-"
                t2["lock_state"] = "-"   # we never really held it
                save(a.id, t2)
                git_sync_push(f"yield({a.id}): {a.agent} lost lock '{t2['locks']}' to {h['id']}")
                die(f"lost lock '{t2['locks']}' race on {a.id} to {h['id']}", 2)

    print(f"claimed {a.id}")


def cmd_complete(a):
    t = load(a.id)
    msg_extra = ""

    if a.role == "feature":
        # Hand off to QA: flip status and domain
        t["status"] = "testing"
        t["domain"] = "qa"
        t["claimed_by"] = "-"
        t["claimed_at"] = "-"

    elif a.role == "qa":
        v = a.verdict or die("qa complete requires --verdict passed|failed|env_error")
        msg_extra = f" {v}"
        if v == "passed":
            # Hand off to doc
            t["status"] = "documenting"
            t["domain"] = "doc"
        elif v == "failed":
            # Send back to feature agent — revert domain to origin
            t["failure_count"] = str(int(t["failure_count"]) + 1)
            if int(t["failure_count"]) >= 3:
                t["status"] = "needs_human"
            else:
                t["status"] = "open"
                t["domain"] = t.get("origin_domain", "-")
        elif v == "env_error":
            # Environment problem — leave in testing, clear claim, no failure_count change
            t["status"] = "testing"
            # domain stays qa
        t["claimed_by"] = "-"
        t["claimed_at"] = "-"

    elif a.role == "doc":
        t["status"] = "done"
        t["claimed_by"] = "-"
        t["claimed_at"] = "-"

    save(a.id, t)
    if not git_sync_push(f"{a.role}({a.id}):{msg_extra or ' complete'} by {a.agent}"):
        die("push failed after retries")
    print(f"completed {a.id}{msg_extra}")


def cmd_fail(a):
    t = load(a.id)

    if getattr(a, "awaiting_info", False):
        # Park the task — does NOT increment failure_count
        t["prev_status"] = t["status"]
        t["status"] = "awaiting_info"
        t["claimed_by"] = "-"
        t["claimed_at"] = "-"
        save(a.id, t)
        git_sync_push(f"await({a.id}): {a.agent} parked awaiting_info")
        print(f"parked {a.id} as awaiting_info (failure_count unchanged)")
        return

    t["failure_count"] = str(int(t["failure_count"]) + 1)

    if a.needs_human or int(t["failure_count"]) >= 3:
        t["status"] = "needs_human"
    else:
        # Revert to unclaimed state appropriate to role
        if a.role == "feature":
            t["status"] = "open"
        elif a.role == "qa":
            t["status"] = "testing"    # stays in qa domain, unclaimed
        elif a.role == "doc":
            t["status"] = "documenting"  # stays in doc domain, unclaimed

    t["claimed_by"] = "-"
    t["claimed_at"] = "-"
    save(a.id, t)
    git_sync_push(f"fail({a.id}): {a.agent} count={t['failure_count']}")
    print(f"failed {a.id} (count={t['failure_count']}, status={t['status']})")


def cmd_release(a):
    """Voluntary unclaim — agent gives up without failure, no failure_count change."""
    t = load(a.id)
    if a.role == "feature" and t["status"] == "in_progress":
        t["status"] = "open"
    # qa/doc: status stays testing/documenting — just clears the claim so another agent can pick it up
    t["claimed_by"] = "-"
    t["claimed_at"] = "-"
    save(a.id, t)
    git_sync_push(f"release({a.id}): {a.agent}")
    print(f"released {a.id}")


def cmd_resume(a):
    """Resume an awaiting_info task — restores prev_status, re-eligible for pickup."""
    t = load(a.id)
    if t["status"] != "awaiting_info":
        die(f"{a.id} is not awaiting_info (status={t['status']})")
    prev = t.get("prev_status", "open")
    if prev == "-":
        prev = "open"
    t["status"] = prev
    t["prev_status"] = "-"
    t["claimed_by"] = "-"
    t["claimed_at"] = "-"
    save(a.id, t)
    git_sync_push(f"resume({a.id}): {a.agent} → {prev}")
    print(f"resumed {a.id} (status → {prev})")


def cmd_unblock(a):
    """Human-only: clear needs_human so a task re-enters the eligible pool."""
    t = load(a.id)
    if t["status"] != "needs_human":
        die(f"{a.id} is not needs_human (status={t['status']})")
    # Revert to the right state based on origin: if domain=qa it was in testing, etc.
    domain = t.get("domain", "-")
    if domain == "qa":
        t["status"] = "testing"
    elif domain == "doc":
        t["status"] = "documenting"
    else:
        t["status"] = "open"
    t["failure_count"] = "0"
    save(a.id, t)
    git_sync_push(f"unblock({a.id}): human cleared needs_human → {t['status']}")
    print(f"unblocked {a.id} (status → {t['status']})")


def cmd_lock_release(a):
    """Release an exclusive lock after its branch merged to main (or was abandoned).
    Called by the supervisor's merge-reaper when it sees the branch land on main, or
    by a human closing a superseded PR. Idempotent: a no-op on an unheld/freed lock."""
    t = load(a.id)
    if t.get("locks", "-") in ("-", ""):
        print(f"{a.id} has no lock to release")
        return
    if t.get("lock_state") != "held":
        print(f"{a.id} lock not held (lock_state={t.get('lock_state', '-')}) — nothing to release")
        return
    t["lock_state"] = "freed"
    save(a.id, t)
    reason = "abandoned" if getattr(a, "abandon", False) else "merged"
    git_sync_push(f"lock-release({a.id}): {t['locks']} freed ({reason}) by {a.agent or 'reaper'}")
    print(f"released lock '{t['locks']}' on {a.id} ({reason})")


def cmd_create(a):
    if os.path.isfile(path_for(a.id)):
        die(f"{a.id} already exists")
    os.makedirs(LEDGER_DIR, exist_ok=True)
    t = dict(DEFAULTS)
    t.update(id=a.id, repo=a.repo, domain=a.domain, origin_domain=a.domain, description=a.desc)
    if a.blocked_by:   t["blocked_by"] = a.blocked_by
    if a.locks:        t["locks"] = a.locks
    if a.spec:         t["spec"] = a.spec
    if a.done_check:   t["done_check"] = a.done_check
    if a.e2e_check:    t["e2e_check"] = a.e2e_check
    if a.lease_hours:  t["lease_hours"] = a.lease_hours
    save(a.id, t)
    git_sync_push(f"create({a.id}) by {a.agent or 'human'}")
    print(f"created {a.id}")


def main():
    p = argparse.ArgumentParser(prog="task")
    sub = p.add_subparsers(dest="cmd", required=True)

    # eligible
    e = sub.add_parser("eligible")
    e.add_argument("--role", required=True)
    e.add_argument("--domain", default="")
    e.add_argument("--repo", default="")

    # show
    s = sub.add_parser("show")
    s.add_argument("id")

    # claim / complete / fail / release / resume — all need id + agent + role
    for name in ("claim", "complete", "fail", "release", "resume"):
        c = sub.add_parser(name)
        c.add_argument("id")
        c.add_argument("--agent", required=True)
        c.add_argument("--role", required=True, choices=list(ROLE_COLUMNS))
        if name == "complete":
            c.add_argument("--verdict", default=None)
        if name == "fail":
            c.add_argument("--needs-human", action="store_true")
            c.add_argument("--awaiting-info", action="store_true")

    # unblock — human-only, no role required
    ub = sub.add_parser("unblock")
    ub.add_argument("id")

    # lock-release — free an exclusive lock post-merge (supervisor reaper or human)
    lr = sub.add_parser("lock-release")
    lr.add_argument("id")
    lr.add_argument("--agent", default=None)
    lr.add_argument("--abandon", action="store_true")

    # create
    cr = sub.add_parser("create")
    cr.add_argument("id")
    for f in ("--repo", "--domain", "--desc"):
        cr.add_argument(f, required=True)
    for f in ("--blocked-by", "--locks", "--spec", "--done-check", "--e2e-check", "--lease-hours", "--agent"):
        cr.add_argument(f, default=None)

    a = p.parse_args()
    run(["git", "pull", "--rebase", "-q"], check=False)

    if a.cmd == "eligible":
        ids = eligible(a.role, a.domain, a.repo)
        if not ids:
            print("NO_ELIGIBLE_TASKS")
            sys.exit(3)
        print("\n".join(ids))
    elif a.cmd == "show":
        for k, v in load(a.id).items():
            print(f"{k}: {v}")
    elif a.cmd == "claim":   cmd_claim(a)
    elif a.cmd == "complete": cmd_complete(a)
    elif a.cmd == "fail":    cmd_fail(a)
    elif a.cmd == "release": cmd_release(a)
    elif a.cmd == "resume":  cmd_resume(a)
    elif a.cmd == "unblock": cmd_unblock(a)
    elif a.cmd == "lock-release": cmd_lock_release(a)
    elif a.cmd == "create":  cmd_create(a)


if __name__ == "__main__":
    main()
