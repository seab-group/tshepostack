#!/usr/bin/env python3
"""
task — deterministic ledger operations for the cstack autonomous loop.
Lives at bin/task in the control repo. Agents invoke this instead of editing
ledger files themselves: the model decides WHAT, this script executes HOW.

Ledger format: one flat key:value file per task at ledger/<TASK-ID>.task
(no nesting, no YAML library needed, trivially mergeable, one task = one file).

Usage:
  task eligible --role feature --domain be --repo <repo-name>    # print eligible task ids, best first
  task show <id>                                                  # print a task's fields
  task claim <id> --agent agent-be --role feature                 # atomic claim (git push is the lock)
  task complete <id> --agent agent-be --role feature              # role-appropriate completion
  task complete <id> --agent agent-qa --role qa --verdict passed|failed|env_error
  task complete <id> --agent agent-doc --role doc [--verdict n/a]
  task fail <id> --agent agent-be --role feature [--needs-human]  # failure_count++, revert claim
  task create <id> --repo R --domain D --desc "..." [--blocked-by A,B] [--spec tasks/X.md] ...
  task release <id> --agent agent-be --role feature               # voluntary unclaim (no failure)
  task unblock <id> --agent tshepo --reason "..."                  # HUMAN ONLY: needs_human -> open
  task sync                                                          # create ledger entries from
                                                                      # tasks/*.md frontmatter (ready: true)

Exit codes: 0 ok · 1 error · 2 lost claim race (pick another task) · 3 nothing eligible
All mutations commit+push the control repo with retry-on-reject (pull --rebase, re-verify, push).
"""

import argparse, datetime, os, re, subprocess, sys
try:  # exit silently when downstream pipe closes early (e.g. | head, grep -q)
    import signal
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)
except (ImportError, AttributeError, ValueError):
    pass

LEDGER_DIR = "ledger"
TASKS_DIR = "tasks"
ROLE_COLUMNS = {  # column ownership, enforced
    "feature": {"status", "claimed_by", "claimed_at", "failure_count"},
    "qa":      {"qa_status", "claimed_at"},   # + documented reopen exception handled in complete()
    "doc":     {"doc_status", "claimed_at"},
}
CLAIM_FIELD  = {"feature": ("status", "in_progress"), "qa": ("qa_status", "testing"), "doc": ("doc_status", "updating")}
DEFAULTS = {"status": "open", "claimed_by": "-", "claimed_at": "-", "blocked_by": "-",
            "failure_count": "0", "lease_hours": "4", "qa_status": "-", "doc_status": "-",
            "spec": "-", "done_check": "-", "e2e_check": "-"}

def die(msg, code=1):
    print(f"task: {msg}", file=sys.stderr); sys.exit(code)

def now_iso():
    return datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

def run(cmd, check=True):
    r = subprocess.run(cmd, capture_output=True, text=True)
    if check and r.returncode != 0:
        die(f"command failed: {' '.join(cmd)}\n{r.stderr.strip()}")
    return r

def path_for(tid):
    return os.path.join(LEDGER_DIR, f"{tid}.task")

def load(tid):
    p = path_for(tid)
    if not os.path.isfile(p):
        die(f"no such task: {tid}")
    fields = dict(DEFAULTS)
    for line in open(p):
        m = re.match(r"^([a-z_]+):\s?(.*)$", line.rstrip("\n"))
        if m:
            fields[m.group(1)] = m.group(2).strip() or "-"
    fields["id"] = fields.get("id", tid)
    return fields

def save(tid, fields):
    order = ["id", "repo", "domain", "status", "claimed_by", "claimed_at", "blocked_by",
             "failure_count", "lease_hours", "spec", "done_check", "e2e_check",
             "qa_status", "doc_status", "description"]
    keys = order + [k for k in fields if k not in order]
    with open(path_for(tid), "w") as f:
        for k in keys:
            if k in fields:
                f.write(f"{k}: {fields[k]}\n")

def all_tasks():
    if not os.path.isdir(LEDGER_DIR):
        return []
    out = []
    for fn in sorted(os.listdir(LEDGER_DIR)):
        if fn.endswith(".task"):
            out.append(load(fn[:-5]))
    return out

def stale(fields, status_field, active_value):
    """True if claimed but lease expired."""
    if fields.get(status_field) != active_value or fields.get("claimed_at", "-") == "-":
        return False
    try:
        claimed = datetime.datetime.fromisoformat(fields["claimed_at"].replace("Z", "+00:00"))
        lease = float(fields.get("lease_hours", "4"))
        return (datetime.datetime.now(datetime.timezone.utc) - claimed).total_seconds() > lease * 3600
    except ValueError:
        return True  # unparseable timestamp = treat as stale

def blocked(fields, index):
    deps = fields.get("blocked_by", "-")
    if deps in ("-", ""):
        return False
    for dep in [d.strip() for d in deps.split(",") if d.strip()]:
        dep_t = index.get(dep)
        if dep_t is None or dep_t.get("status") != "done":
            return True
    return False

def eligible(role, domain, repo):
    index = {t["id"]: t for t in all_tasks()}
    out = []
    for t in index.values():
        if int(t.get("failure_count", "0")) >= 3 or t.get("status") == "needs_human":
            continue
        if domain and t.get("domain") not in (domain, "full"):
            continue
        if repo and t.get("repo", "-") not in (repo, "-"):
            continue
        if role == "feature":
            ok = (t["status"] == "open" and not blocked(t, index)) \
                or stale(t, "status", "in_progress") \
                or stale(t, "status", "awaiting_info")  # asker never answered -> reclaimable
        elif role == "qa":
            ok = t["status"] == "done" and (t["qa_status"] in ("-", "pending") or stale(t, "qa_status", "testing"))
        elif role == "doc":
            ok = t["status"] == "done" and (t["doc_status"] == "-" or stale(t, "doc_status", "updating"))
        else:
            die(f"unknown role: {role}")
        if ok:
            out.append(t)
    if role == "doc":  # prefer QA-verified work
        out.sort(key=lambda t: 0 if t.get("qa_status") == "passed" else 1)
    return [t["id"] for t in out]

def git_sync_push(message, retries=3):
    """Commit ledger changes and push; on reject, rebase and signal caller to re-verify."""
    run(["git", "add", LEDGER_DIR])
    r = subprocess.run(["git", "commit", "-qm", message], capture_output=True, text=True)
    if r.returncode != 0:
        return True  # nothing to commit
    for _ in range(retries):
        if subprocess.run(["git", "push", "-q"], capture_output=True).returncode == 0:
            return True
        run(["git", "pull", "--rebase", "-q"], check=False)
    return False

def cmd_claim(a):
    field, active = CLAIM_FIELD[a.role]
    t = load(a.id)
    # pre-check
    if a.role == "feature" and t["status"] != "open" and not stale(t, "status", "in_progress"):
        die(f"{a.id} not claimable (status={t['status']})", 2)
    t[field] = active
    t["claimed_by"] = a.agent if a.role == "feature" else t.get("claimed_by", "-")
    t["claimed_at"] = now_iso()
    save(a.id, t)
    if not git_sync_push(f"claim({a.id}): {a.agent} [{a.role}]"):
        die("push failed after retries", 1)
    # post-push verify we still own it (rebase may have replayed over a competing claim)
    run(["git", "pull", "--rebase", "-q"], check=False)
    t2 = load(a.id)
    mine = (t2.get("claimed_by") == a.agent) if a.role == "feature" else (t2.get(field) == active)
    if t2.get(field) != active or not mine:
        die(f"lost claim race on {a.id}", 2)
    print(f"claimed {a.id}")

def cmd_complete(a):
    t = load(a.id)
    msg_extra = ""
    if a.role == "feature":
        t["status"], t["claimed_by"], t["claimed_at"] = "done", "-", "-"
    elif a.role == "qa":
        v = a.verdict or die("qa complete requires --verdict passed|failed|env_error")
        t["qa_status"], t["claimed_at"] = v, "-"
        msg_extra = f" {v}"
        if v == "failed":  # documented cross-column exception
            t["failure_count"] = str(int(t["failure_count"]) + 1)
            t["status"] = "needs_human" if int(t["failure_count"]) >= 3 else "open"
    elif a.role == "doc":
        t["doc_status"], t["claimed_at"] = (a.verdict or "updated"), "-"
    save(a.id, t)
    if not git_sync_push(f"{a.role}({a.id}):{msg_extra or ' complete'} by {a.agent}"):
        die("push failed after retries")
    print(f"completed {a.id}{msg_extra}")

def cmd_fail(a):
    t = load(a.id)
    if a.role == "feature" and getattr(a, "awaiting_info", False):
        # Asking a question of another agent: park the task, no failure_count hit.
        if t["status"] != "in_progress":
            die(f"{a.id} is not in_progress (status={t['status']}); cannot mark awaiting_info")
        t["status"] = "awaiting_info"
        t["claimed_by"], t["claimed_at"] = "-", "-"
        save(a.id, t)
        if not git_sync_push(f"awaiting_info({a.id}): {a.agent} asked a question"):
            die("push failed after retries")
        print(f"awaiting_info {a.id}")
        return
    t["failure_count"] = str(int(t["failure_count"]) + 1)
    if a.role == "feature":
        t["status"] = "needs_human" if (a.needs_human or int(t["failure_count"]) >= 3) else "open"
        t["claimed_by"], t["claimed_at"] = "-", "-"
    elif a.role == "qa":
        t["qa_status"], t["claimed_at"] = "-", "-"
    elif a.role == "doc":
        t["doc_status"], t["claimed_at"] = "-", "-"
    save(a.id, t)
    if not git_sync_push(f"fail({a.id}): {a.agent} count={t['failure_count']}"):
        die("push failed after retries")
    print(f"failed {a.id} (count={t['failure_count']}, status={t['status']})")

def cmd_resume(a):
    """Agent-permitted (NOT human-only): the agent who was asked a question answers it.
    awaiting_info -> open. If they ALSO can't answer, they use `task fail --needs-human`
    instead of this (which escalates to mailboxes/tshepo.md per AGENT_BASE)."""
    t = load(a.id)
    if t["status"] != "awaiting_info":
        die(f"{a.id} is not awaiting_info (status={t['status']}); nothing to resume")
    t["status"] = "open"
    t["claimed_by"], t["claimed_at"] = "-", "-"
    save(a.id, t)
    if not git_sync_push(f"resume({a.id}): {a.agent} answered — ready for re-pickup"):
        die("push failed after retries")
    print(f"resumed {a.id}")

def cmd_release(a):
    t = load(a.id)
    field, active = CLAIM_FIELD[a.role]
    if t.get(field) == active:
        t[field] = "open" if a.role == "feature" else "-"
        t["claimed_at"] = "-"
        if a.role == "feature":
            t["claimed_by"] = "-"
    save(a.id, t)
    git_sync_push(f"release({a.id}): {a.agent}")
    print(f"released {a.id}")

def cmd_unblock(a):
    """Human-only: move a needs_human task back to open with a recorded reason.
    The ONLY sanctioned way to reverse needs_human — refuses any other transition,
    so it cannot become a general-purpose ledger editor."""
    t = load(a.id)
    if t["status"] != "needs_human":
        die(f"{a.id} is not needs_human (status={t['status']}); nothing to unblock")
    if not a.reason or not a.reason.strip():
        die("--reason is required (recorded in the commit and PROGRESS)")
    t["status"] = "open"
    t["claimed_by"], t["claimed_at"] = "-", "-"
    # Deliberately do NOT reset failure_count: it remains as history of the prior block.
    save(a.id, t)
    if not git_sync_push(f"unblock({a.id}) by {a.agent}: {a.reason.strip()}"):
        die("push failed after retries")
    print(f"unblocked {a.id}: {a.reason.strip()}")

def parse_frontmatter(path):
    """Parse a simple `---\\nkey: value\\n---` block at the top of a markdown file.
    Returns (fields_dict, title) or (None, None) if no frontmatter block is present.
    `title` is taken from the first '# <ID> — <title>' heading, if any."""
    lines = open(path, encoding="utf-8").read().splitlines()
    if not lines or lines[0].strip() != "---":
        return None, None
    fm, i = {}, 1
    while i < len(lines) and lines[i].strip() != "---":
        m = re.match(r"^([A-Za-z_][A-Za-z0-9_]*):\s?(.*)$", lines[i])
        if m:
            fm[m.group(1).strip()] = m.group(2).strip()
        i += 1
    title = None
    for line in lines[i:]:
        m = re.match(r"^#\s+\S+\s+[—-]\s+(.+)$", line.strip())
        if m:
            title = m.group(1).strip()
            break
    return fm, title

def cmd_sync(a):
    """Create ledger entries for tasks/*.md specs with frontmatter `ready: true` that
    don't have a ledger entry yet. One pull, N writes, ONE commit+push. Idempotent:
    specs that already have a ledger entry, or aren't ready, are skipped (reported)."""
    created, not_ready, exists, errors = [], [], [], []
    if not os.path.isdir(TASKS_DIR):
        print("NO_SPECS")
        return
    for fn in sorted(os.listdir(TASKS_DIR)):
        if not fn.endswith(".md") or fn == "TASK_TEMPLATE.md":
            continue
        tid = fn[:-3]
        spec_path = os.path.join(TASKS_DIR, fn)
        if os.path.isfile(path_for(tid)):
            exists.append(tid); continue
        fm, title = parse_frontmatter(spec_path)
        if fm is None:
            continue  # no frontmatter at all = not a sync-managed spec; ignore silently
        if fm.get("ready", "false").lower() != "true":
            not_ready.append(tid); continue
        missing = [k for k in ("repo", "domain") if not fm.get(k)]
        if missing:
            errors.append((tid, f"missing required frontmatter field(s): {', '.join(missing)}"))
            continue
        t = dict(DEFAULTS)
        t.update(id=tid, repo=fm["repo"], domain=fm["domain"],
                 description=fm.get("desc") or title or tid,
                 spec=f"{TASKS_DIR}/{fn}")
        for k_fm, k_ledger in (("blocked_by", "blocked_by"), ("done_check", "done_check"),
                                ("e2e_check", "e2e_check"), ("lease_hours", "lease_hours")):
            if fm.get(k_fm):
                t[k_ledger] = fm[k_fm]
        save(tid, t)
        created.append(tid)

    if created:
        run(["git", "add", LEDGER_DIR])
        if not git_sync_push(f"sync: register {len(created)} task(s) from tasks/*.md — " + ", ".join(created)):
            die("push failed after retries")

    print(f"created: {len(created)}" + (f" ({', '.join(created)})" if created else ""))
    print(f"already registered: {len(exists)}")
    print(f"not ready (ready != true): {len(not_ready)}" + (f" ({', '.join(not_ready)})" if not_ready else ""))
    if errors:
        print(f"ERRORS: {len(errors)}")
        for tid, msg in errors:
            print(f"  {tid}: {msg}")
        sys.exit(1)

def cmd_create(a):
    if os.path.isfile(path_for(a.id)):
        die(f"{a.id} already exists")
    os.makedirs(LEDGER_DIR, exist_ok=True)
    t = dict(DEFAULTS)
    t.update(id=a.id, repo=a.repo, domain=a.domain, description=a.desc)
    if a.blocked_by: t["blocked_by"] = a.blocked_by
    if a.spec: t["spec"] = a.spec
    if a.done_check: t["done_check"] = a.done_check
    if a.e2e_check: t["e2e_check"] = a.e2e_check
    if a.lease_hours: t["lease_hours"] = a.lease_hours
    save(a.id, t)
    git_sync_push(f"create({a.id}) by {a.agent or 'human'}")
    print(f"created {a.id}")

def main():
    p = argparse.ArgumentParser(prog="task")
    sub = p.add_subparsers(dest="cmd", required=True)

    e = sub.add_parser("eligible"); e.add_argument("--role", required=True); e.add_argument("--domain", default=""); e.add_argument("--repo", default="")
    s = sub.add_parser("show"); s.add_argument("id")
    for name in ("claim", "complete", "fail", "release", "resume"):
        c = sub.add_parser(name); c.add_argument("id")
        c.add_argument("--agent", required=True); c.add_argument("--role", required=True, choices=list(ROLE_COLUMNS))
        if name == "complete": c.add_argument("--verdict", default=None)
        if name == "fail":
            c.add_argument("--needs-human", action="store_true")
            c.add_argument("--awaiting-info", action="store_true",
                            help="Park as awaiting_info instead of failing (no failure_count hit). "
                                 "Mailbox the agent who can answer, then exit.")
    cr = sub.add_parser("create"); cr.add_argument("id")
    for f in ("--repo", "--domain", "--desc"): cr.add_argument(f, required=True)
    for f in ("--blocked-by", "--spec", "--done-check", "--e2e-check", "--lease-hours", "--agent"): cr.add_argument(f, default=None)

    ub = sub.add_parser("unblock", description="HUMAN ONLY: reopen a needs_human task with a recorded reason.")
    ub.add_argument("id")
    ub.add_argument("--agent", default="human")
    ub.add_argument("--reason", required=True)

    sub.add_parser("sync", description="Create ledger entries from tasks/*.md frontmatter (ready: true). One commit for the whole batch.")

    a = p.parse_args()
    run(["git", "pull", "--rebase", "-q"], check=False)  # fresh view before any read/write
    if a.cmd == "eligible":
        ids = eligible(a.role, a.domain, a.repo)
        if not ids: print("NO_ELIGIBLE_TASKS"); sys.exit(3)
        print("\n".join(ids))
    elif a.cmd == "show":
        for k, v in load(a.id).items(): print(f"{k}: {v}")
    elif a.cmd == "claim": cmd_claim(a)
    elif a.cmd == "complete": cmd_complete(a)
    elif a.cmd == "fail": cmd_fail(a)
    elif a.cmd == "resume": cmd_resume(a)
    elif a.cmd == "release": cmd_release(a)
    elif a.cmd == "unblock": cmd_unblock(a)
    elif a.cmd == "sync": cmd_sync(a)
    elif a.cmd == "create": cmd_create(a)

if __name__ == "__main__":
    main()
